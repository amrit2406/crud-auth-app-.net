<Window x:Class="auth_app.Views.Products.ProductEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Product"
        Height="300"
        Width="350">

    <Grid Margin="20">

        <StackPanel>

            <TextBlock Text="Name"/>

            <TextBox
                x:Name="NameBox"
                Margin="0,5,0,10"/>

            <TextBlock Text="Price"/>

            <TextBox
                x:Name="PriceBox"
                Margin="0,5,0,10"/>

            <TextBlock Text="Quantity"/>

            <TextBox
                x:Name="QuantityBox"
                Margin="0,5,0,10"/>

            <Button
                Content="Save"
                Width="100"
                Height="35"
                Click="Save_Click"/>

        </StackPanel>

    </Grid>
</Window>