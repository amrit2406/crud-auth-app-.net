<Window x:Class="auth_app.Views.Users.UserCreateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create User"
        Height="300"
        Width="400">

    <Grid Margin="20">

        <StackPanel>

            <TextBlock Text="Username"/>

            <TextBox
                x:Name="UsernameTextBox"
                Margin="0,5,0,10"/>

            <TextBlock Text="Password"/>

            <PasswordBox
                x:Name="PasswordBox"
                Margin="0,5,0,10"/>

            <TextBlock Text="Role"/>

            <ComboBox
    x:Name="RoleComboBox"
    DisplayMemberPath="Name"
    SelectedValuePath="Id"
    Margin="0,5,0,10"/>

            <CheckBox
                x:Name="ActiveCheckBox"
                Content="Active"
                IsChecked="True"
                Margin="0,0,0,20"/>

            <Button
                Content="Save"
                Height="35"
                Click="Save_Click"/>

        </StackPanel>

    </Grid>

</Window>