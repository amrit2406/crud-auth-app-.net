<Window x:Class="auth_app.Views.Dashboard.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dashboard"
        Height="500"
        Width="900">

    <Grid>

        <StackPanel Margin="20">

            <TextBlock
                Text="Dashboard"
                FontSize="28"
                Margin="0,0,0,20"/>

            <TextBlock
                x:Name="UserText"
                FontSize="16"
                Margin="0,0,0,20"/>

            <Button
                x:Name="UsersButton"
                Content="User Management"
                Height="40"
                Margin="0,0,0,10"
                Click="UsersButton_Click"/>

            <Button
                x:Name="ProductsButton"
                Content="Product Management"
                Height="40"
                Margin="0,0,0,10"
                Click="ProductManagementButton_Click"/>

        </StackPanel>

    </Grid>

</Window>